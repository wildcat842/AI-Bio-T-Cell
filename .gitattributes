# Git LFS - 대용량 바이너리 파일 처리
*.pdf filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.pptx filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.tiff filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.h5ad filter=lfs diff=lfs merge=lfs -text
*.rds filter=lfs diff=lfs merge=lfs -text
# 텍스트 파일 정규화
*.md text eol=lf
*.py text eol=lf
*.R text eol=lf
*.r text eol=lf
*.Rmd text eol=lf
*.ipynb text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
# Windows 호환성
*.bat text eol=crlf
*.ps1 text eol=crlf
# 언어 통계에서 제외 (GitHub linguist)
docs/** linguist-documentation
obsidian/** linguist-documentation
references/** linguist-vendored
notebooks/** linguist-documentation
